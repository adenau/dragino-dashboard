DRAGINO_API_URL=https://nam1.cloud.thethings.network/api/v3/as/applications/your-application/packages/storage/uplink_message
DRAGINO_API_TOKEN=replace_with_your_token
DRAGINO_DEVICE_ID=temp-sensor-001

# Environment: dev or prod
DRAGINO_ENV=dev

# Database backend: sqlite or mysql
DRAGINO_DATABASE_BACKEND=sqlite

# Database configuration
# SQLite settings (used when DRAGINO_DATABASE_BACKEND=sqlite)
DRAGINO_DATABASE_PATH=sensor_data.db

# Optional explicit SQLAlchemy database URL (overrides all DB settings below)
# SQLite example:
# DRAGINO_DATABASE_URL=sqlite:///sensor_data.db
# MySQL example:
# DRAGINO_DATABASE_URL=mysql+pymysql://dragino:change_me@localhost:3306/dragino_dashboard

# MySQL settings (used when DRAGINO_DATABASE_BACKEND=mysql and DRAGINO_DATABASE_URL is not set)
DRAGINO_MYSQL_HOST=localhost
DRAGINO_MYSQL_PORT=3306
DRAGINO_MYSQL_DATABASE=dragino_dashboard
DRAGINO_MYSQL_USER=dragino
DRAGINO_MYSQL_PASSWORD=change_me

DRAGINO_WEB_HOST=0.0.0.0
DRAGINO_WEB_PORT=5000

DRAGINO_COLLECTION_INTERVAL=900
DRAGINO_LOOKBACK_HOURS=192
DRAGINO_ENABLE_BACKGROUND_COLLECTOR=true